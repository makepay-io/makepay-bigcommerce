{
  "name": "makepay-bigcommerce",
  "version": "0.1.0",
  "description": "BigCommerce OAuth app starter for MakePay payment links and order reconciliation.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "scan": "node scripts/scan.mjs",
    "validate": "npm run build && npm test && npm run scan"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "jose": "6.2.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "@types/supertest": "7.2.0",
    "supertest": "7.2.2",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
